.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.summary-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.summary-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.category-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  border: 1rpx solid #e0e0e0;
}

.category-tag.active {
  background-color: #4CAF50;
  color: #ffffff;
  border-color: #4CAF50;
}

.activity-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.activity-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.activity-item {
  width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.activity-item:active {
  background-color: #e8f5e9;
  transform: scale(0.95);
}

.activity-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.activity-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.activity-met {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.empty-state {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
}

.modal-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 20rpx;
}

.duration-input {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.calc-result {
  text-align: center;
  padding: 30rpx 0;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.calc-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.calc-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #4CAF50;
}

.calc-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.save-exercise-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.records-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-records {
  text-align: center;
  padding: 60rpx 0;
}

.empty-records .empty-hint {
  font-size: 24rpx;
  color: #cccccc;
  margin-top: 12rpx;
  display: block;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-detail {
  font-size: 22rpx;
  color: #999999;
}

.record-delete {
  font-size: 24rpx;
  color: #ff4757;
  padding: 8rpx 16rpx;
}
