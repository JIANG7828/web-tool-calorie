.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.weight-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 8rpx;
}

.weight-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.bmi-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.bmi-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.bmi-value {
  font-size: 36rpx;
  font-weight: bold;
}

.bmi-status {
  font-size: 24rpx;
}

.input-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input-section {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.input-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weight-input {
  flex: 1;
  font-size: 32rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}

.input-unit {
  font-size: 24rpx;
  color: #999999;
}

.save-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  padding: 16rpx 32rpx;
}

.target-section {
  display: flex;
  align-items: center;
}

.target-section .input-title {
  margin-bottom: 0;
  margin-right: 16rpx;
}

.target-input {
  flex: 1;
  font-size: 28rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  text-align: center;
}

.chart-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}

.empty-chart {
  text-align: center;
  padding: 80rpx 0;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

.records-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-records {
  text-align: center;
  padding: 40rpx 0;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.record-date {
  font-size: 24rpx;
  color: #999999;
}

.record-weight {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.record-delete {
  font-size: 24rpx;
  color: #ff4757;
  padding: 8rpx 16rpx;
}
