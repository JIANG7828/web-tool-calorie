.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  border-radius: 50%;
}

.nav-icon {
  font-size: 24rpx;
  color: #4CAF50;
}

.nav-icon.disabled {
  color: #cccccc;
}

.date-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.date-tag {
  font-size: 20rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.summary-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.calorie-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
}

.calorie-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
  display: block;
}

.macro-bars {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.macro-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.macro-bar {
  flex: 1;
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.macro-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.protein-fill { background-color: #FF6B6B; }
.fat-fill { background-color: #FFD93D; }
.carb-fill { background-color: #6BCB77; }

.macro-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  width: 140rpx;
  text-align: right;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

.meal-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.meal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.meal-total {
  font-size: 24rpx;
  color: #666666;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.record-left {
  flex: 1;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.record-detail {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
}

.record-macro {
  font-size: 20rpx;
  color: #b0b0b0;
  display: block;
  margin-top: 4rpx;
}

.record-actions {
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
}

.action-edit {
  font-size: 24rpx;
  color: #2196F3;
  padding: 8rpx 12rpx;
}

.action-delete {
  font-size: 24rpx;
  color: #ff4757;
  padding: 8rpx 12rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
}

.edit-food-name {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 30rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.edit-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 20rpx;
}

.edit-input {
  flex: 1;
  font-size: 32rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.save-edit-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
}
