.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header {
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.header-date {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

.meal-filter-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.meal-filter-list {
  display: inline-flex;
  gap: 12rpx;
}

.meal-filter-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.meal-filter-btn.active {
  background: #4CAF50;
  color: #fff;
}

.meal-filter-btn.has-record {
  border: 2rpx solid #4CAF50;
}

.check-mark {
  color: #4CAF50;
  font-weight: bold;
  font-size: 22rpx;
  margin-left: 4rpx;
}

.timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline-line {
  position: absolute;
  left: 18rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(to bottom, #4CAF50, #81C784);
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -32rpx;
  top: 28rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  z-index: 1;
}

.timeline-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.timeline-meal-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meal-emoji {
  font-size: 28rpx;
}

.meal-type-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.timeline-time {
  font-size: 22rpx;
  color: #999;
}

.timeline-content {
  margin-bottom: 12rpx;
}

.food-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.food-macros {
  display: flex;
  gap: 12rpx;
}

.macro-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.macro-tag.protein {
  background: #FFE0E0;
  color: #FF6B6B;
}

.macro-tag.fat {
  background: #FFF9D0;
  color: #FFD93D;
}

.macro-tag.carbs {
  background: #E0F5E0;
  color: #6BCB77;
}

.timeline-calorie {
  text-align: right;
  margin-bottom: 12rpx;
}

.cal-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

.cal-unit {
  font-size: 20rpx;
  color: #999;
}

.timeline-actions {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 12rpx;
}

.action-delete {
  font-size: 24rpx;
  color: #ff4757;
  padding: 6rpx 16rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  display: block;
}

.add-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #fff;
  text-align: center;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.1);
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.add-text {
  font-size: 32rpx;
  font-weight: 600;
}
