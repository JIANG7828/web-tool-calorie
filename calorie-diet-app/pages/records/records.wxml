<view class="container">
  <view class="header">
    <text class="header-title">饮食记录</text>
    <text class="header-date">{{dateLabel}} · 今日摄入 {{todayCal}} 千卡</text>
  </view>

  <scroll-view class="meal-filter-scroll" scroll-x="{{true}}">
    <view class="meal-filter-list">
      <view class="meal-filter-btn {{mealFilter === 'all' ? 'active' : ''}}" bindtap="onMealFilterChange" data-meal="all">
        <text>全部</text>
      </view>
      <view class="meal-filter-btn {{mealFilter === 'breakfast' ? 'active' : ''}} {{hasBreakfast ? 'has-record' : ''}}" bindtap="onMealFilterChange" data-meal="breakfast">
        <text wx:if="{{hasBreakfast}}">☀️</text>
        <text>早餐</text>
        <text class="check-mark" wx:if="{{hasBreakfast}}">✓</text>
      </view>
      <view class="meal-filter-btn {{mealFilter === 'lunch' ? 'active' : ''}} {{hasLunch ? 'has-record' : ''}}" bindtap="onMealFilterChange" data-meal="lunch">
        <text wx:if="{{hasLunch}}">🌞</text>
        <text>午餐</text>
        <text class="check-mark" wx:if="{{hasLunch}}">✓</text>
      </view>
      <view class="meal-filter-btn {{mealFilter === 'dinner' ? 'active' : ''}} {{hasDinner ? 'has-record' : ''}}" bindtap="onMealFilterChange" data-meal="dinner">
        <text wx:if="{{hasDinner}}">🌙</text>
        <text>晚餐</text>
        <text class="check-mark" wx:if="{{hasDinner}}">✓</text>
      </view>
      <view class="meal-filter-btn {{mealFilter === 'snack' ? 'active' : ''}} {{hasSnack ? 'has-record' : ''}}" bindtap="onMealFilterChange" data-meal="snack">
        <text wx:if="{{hasSnack}}">🍎</text>
        <text>加餐</text>
        <text class="check-mark" wx:if="{{hasSnack}}">✓</text>
      </view>
    </view>
  </scroll-view>

  <view class="timeline" wx:if="{{filteredRecords.length > 0}}">
    <view class="timeline-line"></view>
    <view class="timeline-item" wx:for="{{filteredRecords}}" wx:key="id">
      <view class="timeline-dot" style="background: {{item.mealType === 'breakfast' ? '#FFD93D' : (item.mealType === 'lunch' ? '#FF9800' : (item.mealType === 'dinner' ? '#6366F1' : '#4CAF50'))}}"></view>
      <view class="timeline-card">
        <view class="timeline-header">
          <view class="timeline-meal-type">
            <text class="meal-emoji">{{item.mealType === 'breakfast' ? '☀️' : (item.mealType === 'lunch' ? '🌞' : (item.mealType === 'dinner' ? '🌙' : '🍎'))}}</text>
            <text class="meal-type-text">{{mealTypeNames[item.mealType]}}</text>
          </view>
          <text class="timeline-time">{{item.time}}</text>
        </view>
        <view class="timeline-content">
          <text class="food-name">{{item.foodName}}</text>
          <view class="food-macros">
            <text class="macro-tag protein">蛋 {{item.macro ? item.macro.protein : 0}}g</text>
            <text class="macro-tag fat">脂 {{item.macro ? item.macro.fat : 0}}g</text>
            <text class="macro-tag carbs">碳 {{item.macro ? item.macro.carbs : 0}}g</text>
          </view>
        </view>
        <view class="timeline-calorie">
          <text class="cal-value">{{item.calorie}}</text>
          <text class="cal-unit">千卡</text>
        </view>
        <view class="timeline-actions">
          <text class="action-delete" bindtap="onRecordDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">暂无饮食记录</text>
    <text class="empty-hint">点击下方按钮记录今日饮食</text>
  </view>

  <view class="add-btn" bindtap="goToAddFood">
    <text class="add-icon">+</text>
    <text class="add-text">记录饮食</text>
  </view>
</view>
