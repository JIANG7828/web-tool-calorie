.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.greeting {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 10rpx 16rpx;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.week-arrow {
  font-size: 36rpx;
  color: #4CAF50;
  padding: 10rpx 16rpx;
  font-weight: bold;
}

.week-dates {
  flex: 1;
  white-space: nowrap;
}

.week-date {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  margin: 0 8rpx;
  border-radius: 12rpx;
  background: #fff;
}

.week-date.today {
  background: #E8F5E9;
}

.week-date.selected {
  background: #4CAF50;
}

.week-date.selected .week-day,
.week-date.selected .week-num {
  color: #fff;
}

.week-day {
  font-size: 20rpx;
  color: #999;
}

.week-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.target-mode {
  margin-bottom: 16rpx;
  text-align: center;
}

.target-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.target-badge.fat {
  background: #FFE0B2;
  color: #FF9800;
}

.target-badge.keep {
  background: #E0F2F1;
  color: #009688;
}

.target-badge.muscle {
  background: #E3F2FD;
  color: #2196F3;
}

.streak-badge {
  font-size: 24rpx;
  background-color: #FFF3E0;
  color: #FF9800;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.header-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.calorie-ring-container {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 30rpx;
}

.calorie-ring {
  width: 320rpx;
  height: 320rpx;
}

.calorie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.calorie-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.calorie-number.over-goal {
  color: #FFE082;
}

.calorie-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.calorie-goal {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
}

.macro-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.macro-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  min-width: 120rpx;
}

.macro-val {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.macro-name {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.calorie-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.calorie-detail-row {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.detail-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.detail-value.positive {
  color: #81C784;
}

.detail-value.negative {
  color: #FFE082;
}

.quick-entry-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-entry {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.entry-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.entry-name {
  font-size: 22rpx;
  color: #333;
}

.ai-banner {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  color: #fff;
}

.ai-banner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.ai-banner-content {
  flex: 1;
}

.ai-banner-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
}

.ai-banner-desc {
  font-size: 22rpx;
  opacity: 0.9;
}

.ai-banner-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.water-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.water-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.water-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.water-count {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
}

.water-progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #e0f2f1;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.water-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50 0%, #81C784 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.water-grid {
  display: flex;
  justify-content: space-between;
}

.water-dot {
  font-size: 28rpx;
  color: #e0e0e0;
}

.water-dot.filled {
  color: #4CAF50;
}

.ai-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-left: 6rpx solid #4CAF50;
}

.ai-header {
  margin-bottom: 16rpx;
}

.ai-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.ai-suggestion {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.ai-meal-rec {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.ai-foods {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.ai-foods-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 8rpx;
}

.ai-food-item {
  font-size: 22rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.ai-exercise {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ai-exercise-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 8rpx;
}

.ai-exercise-item {
  font-size: 22rpx;
  background-color: #FFF3E0;
  color: #FF9800;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.ai-loading {
  text-align: center;
  padding: 40rpx 30rpx;
}

.ai-loading-text {
  font-size: 26rpx;
  color: #999999;
}

.quick-add-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-count {
  font-size: 24rpx;
  color: #999999;
}

.meal-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.meal-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  border: none;
  transition: all 0.3s ease;
}

.meal-btn:active {
  transform: scale(0.95);
  background-color: #f0f0f0;
}

.meal-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.meal-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.meal-cal {
  font-size: 20rpx;
  color: #999999;
}

.meal-btn.breakfast {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.meal-btn.lunch {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.meal-btn.dinner {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.meal-btn.snack {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
}

.records-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

.meal-groups {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.meal-group {
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.meal-group:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.meal-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.meal-group-total {
  font-size: 24rpx;
  color: #666666;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.record-item:active {
  background-color: #f0f0f0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.record-detail {
  font-size: 22rpx;
  color: #999999;
}

.record-time {
  font-size: 22rpx;
  color: #cccccc;
  margin-right: 20rpx;
}

.delete-btn {
  padding: 12rpx 24rpx;
  background-color: #ff4757;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 8rpx;
  border: none;
}
