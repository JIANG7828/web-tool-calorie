<view class="container">
  <view class="greeting">
    <text class="greeting-text" wx:if="{{nickname}}">你好，{{nickname}}</text>
    <text class="greeting-text" wx:else>你好</text>
    <text class="streak-badge" wx:if="{{streak > 0}}">🔥 {{streak}}天</text>
  </view>

  <view class="week-nav">
    <text class="week-arrow" bindtap="goPrevWeek">‹</text>
    <scroll-view class="week-dates" scroll-x="{{true}}" scroll-into-view="week-{{today}}">
      <view class="week-date {{item.isToday ? 'today' : ''}} {{today === item.date ? 'selected' : ''}}" wx:for="{{weekDates}}" wx:key="date" id="week-{{item.date}}" bindtap="selectDate" data-date="{{item.date}}">
        <text class="week-day">{{item.dayName}}</text>
        <text class="week-num">{{item.dayNum}}</text>
      </view>
    </scroll-view>
    <text class="week-arrow" bindtap="goNextWeek">›</text>
  </view>

  <view class="target-mode" wx:if="{{targetModeText}}">
    <text class="target-badge {{targetMode}}">{{targetModeText}}</text>
  </view>

  <view class="header-card">
    <view class="calorie-ring-container">
      <canvas type="2d" id="calorieRing" class="calorie-ring"></canvas>
      <view class="calorie-center">
        <text class="calorie-number {{isOverGoal ? 'over-goal' : ''}}">{{todayTotal}}</text>
        <text class="calorie-unit">千卡</text>
        <text class="calorie-goal">目标 {{goal}}</text>
      </view>
    </view>

    <view class="macro-row">
      <view class="macro-chip protein">
        <text class="macro-val">{{macros.protein}}g</text>
        <text class="macro-name">蛋白质</text>
      </view>
      <view class="macro-chip fat">
        <text class="macro-val">{{macros.fat}}g</text>
        <text class="macro-name">脂肪</text>
      </view>
      <view class="macro-chip carbs">
        <text class="macro-val">{{macros.carbs}}g</text>
        <text class="macro-name">碳水</text>
      </view>
    </view>

    <view class="calorie-stats">
      <view class="stat-item">
        <text class="stat-value">{{remaining}}</text>
        <text class="stat-label">剩余</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{exerciseCalories}}</text>
        <text class="stat-label">运动消耗</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{percentage}}%</text>
        <text class="stat-label">完成</text>
      </view>
    </view>

    <view class="calorie-detail-row">
      <view class="detail-item">
        <text class="detail-label">基础消耗</text>
        <text class="detail-value">{{tdee}}千卡</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">热量缺口</text>
        <text class="detail-value {{calorieGap >= 0 ? 'positive' : 'negative'}}">{{calorieGap >= 0 ? '+' : ''}}{{calorieGap}}千卡</text>
      </view>
    </view>
  </view>

  <view class="quick-entry-grid">
    <view class="quick-entry" bindtap="goToEvaluation">
      <text class="entry-icon">📊</text>
      <text class="entry-name">健康评估</text>
    </view>
    <view class="quick-entry" bindtap="goToCheckin">
      <text class="entry-icon">📅</text>
      <text class="entry-name">打卡中心</text>
    </view>
    <view class="quick-entry" bindtap="goToWeight">
      <text class="entry-icon">⚖️</text>
      <text class="entry-name">体重管理</text>
    </view>
    <view class="quick-entry" bindtap="goToFoodDatabase">
      <text class="entry-icon">🔍</text>
      <text class="entry-name">食物库</text>
    </view>
  </view>

  <view class="water-card">
    <view class="water-header">
      <text class="water-title">💧 饮水记录</text>
      <text class="water-count">{{waterCount}}/{{waterGoal}} 杯</text>
    </view>
    <view class="water-progress-bar">
      <view class="water-fill" style="width: {{waterCount >= waterGoal ? 100 : (waterCount / waterGoal * 100)}}%"></view>
    </view>
    <view class="water-grid">
      <view wx:for="{{[0,1,2,3,4,5,6,7]}}" wx:key="{{item}}" class="water-dot {{item < waterCount ? 'filled' : ''}}" bindtap="addWater" data-index="{{item}}">
        <text wx:if="{{item < waterCount}}">💧</text>
        <text wx:else>○</text>
      </view>
    </view>
  </view>

  <view class="ai-card" wx:if="{{aiSuggestion}}">
    <view class="ai-header">
      <text class="ai-title">🤖 AI 智能建议</text>
    </view>
    <text class="ai-suggestion">{{aiSuggestion.suggestion}}</text>
    <text class="ai-meal-rec">{{aiSuggestion.nextMealRecommendation}}</text>
    <view wx:if="{{aiSuggestion.recommendedFoods && aiSuggestion.recommendedFoods.length > 0}}" class="ai-foods">
      <text class="ai-foods-label">推荐食物：</text>
      <text class="ai-food-item" wx:for="{{aiSuggestion.recommendedFoods}}" wx:key="{{index}}" wx:for-item="food">{{food}} </text>
    </view>
    <view wx:if="{{aiSuggestion.exerciseTips && aiSuggestion.exerciseTips.length > 0}}" class="ai-exercise">
      <text class="ai-exercise-label">运动建议：</text>
      <text class="ai-exercise-item" wx:for="{{aiSuggestion.exerciseTips}}" wx:key="{{index}}" wx:for-item="tip">{{tip}} </text>
    </view>
  </view>

  <view class="ai-card ai-loading" wx:elif="{{aiLoading}}">
    <text class="ai-loading-text">🤖 AI 正在生成建议...</text>
  </view>

  <view class="ai-banner" bindtap="goFoodRecognition">
    <text class="ai-banner-icon">📷</text>
    <view class="ai-banner-content">
      <text class="ai-banner-title">AI 拍照识食物</text>
      <text class="ai-banner-desc">拍照即可自动识别食物热量</text>
    </view>
    <text class="ai-banner-arrow">›</text>
  </view>

  <view class="quick-add-section">
    <text class="section-title">快速添加</text>
    <view class="meal-buttons">
      <button class="meal-btn breakfast" data-meal="breakfast" bindtap="addFood">
        <text class="meal-icon">☀️</text>
        <text class="meal-name">早餐</text>
        <text class="meal-cal">{{getMealTotal('breakfast')}}千卡</text>
      </button>
      <button class="meal-btn lunch" data-meal="lunch" bindtap="addFood">
        <text class="meal-icon">🌞</text>
        <text class="meal-name">午餐</text>
        <text class="meal-cal">{{getMealTotal('lunch')}}千卡</text>
      </button>
      <button class="meal-btn dinner" data-meal="dinner" bindtap="addFood">
        <text class="meal-icon">🌙</text>
        <text class="meal-name">晚餐</text>
        <text class="meal-cal">{{getMealTotal('dinner')}}千卡</text>
      </button>
      <button class="meal-btn snack" data-meal="snack" bindtap="addFood">
        <text class="meal-icon">🍎</text>
        <text class="meal-name">加餐</text>
        <text class="meal-cal">{{getMealTotal('snack')}}千卡</text>
      </button>
    </view>
  </view>

  <view class="records-section">
    <view class="section-header">
      <text class="section-title">今日记录</text>
      <text class="record-count">{{records.length}} 条</text>
    </view>

    <view wx:if="{{records.length === 0}}" class="empty-state">
      <text class="empty-text">暂无记录</text>
      <text class="empty-hint">点击上方按钮添加今日饮食</text>
    </view>

    <view wx:else class="meal-groups">
      <block wx:for="{{['breakfast', 'lunch', 'dinner', 'snack']}}" wx:key="{{item}}">
        <view wx:if="{{groupedRecords[item].length > 0}}" class="meal-group">
          <view class="meal-group-header">
            <text class="meal-group-title">{{mealTypes[item]}}</text>
            <text class="meal-group-total">{{getMealTotal(item)}}千卡</text>
          </view>
          <view class="record-list">
            <view wx:for="{{groupedRecords[item]}}" wx:key="{{item.id}}" class="record-item">
              <view class="record-info">
                <text class="record-name">{{item.foodName}}</text>
                <text class="record-detail" wx:if="{{item.macro}}">蛋{{item.macro.protein}}g 脂{{item.macro.fat}}g 碳{{item.macro.carbs}}g</text>
                <text class="record-detail" wx:else>{{item.portion}}{{item.portionUnit}} · {{item.calorie}}千卡</text>
              </view>
              <view class="delete-btn" data-id="{{item.id}}" bindtap="deleteRecord">
                <text>删除</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
