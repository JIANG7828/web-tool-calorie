.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.profile-header {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  color: #ffffff;
}

.avatar-info {
  flex: 1;
}

.nickname-input {
  font-size: 32rpx;
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  width: 100%;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666666;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  padding: 12rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  text-align: right;
}

.form-unit {
  width: 60rpx;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-left: 16rpx;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  padding: 12rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.target-grid {
  display: flex;
  gap: 20rpx;
}

.target-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.target-item.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #4CAF50;
}

.target-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.target-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.activity-item.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #4CAF50;
}

.activity-info {
  flex: 1;
}

.activity-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.activity-desc {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.activity-check {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: bold;
}

.goal-card {
  text-align: center;
}

.goal-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
}

.goal-unit {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.bmi-card {
  text-align: center;
}

.bmi-number {
  font-size: 72rpx;
  font-weight: bold;
  display: block;
}

.bmi-label {
  font-size: 28rpx;
  margin-top: 8rpx;
  display: block;
}

.week-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.week-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.week-item.today {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.week-day {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.week-day.today-text {
  color: #4CAF50;
  font-weight: 600;
}

.week-cal {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.week-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.summary-item {
  font-size: 24rpx;
  color: #666666;
}

.save-btn {
  width: 90%;
  margin: 40rpx auto 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.save-btn:active {
  transform: scale(0.98);
}

.save-btn.saved {
  background: linear-gradient(135deg, #66BB6A 0%, #A5D6A7 100%);
}

.saved-tip {
  text-align: center;
  padding: 16rpx;
}

.saved-tip text {
  color: #4CAF50;
  font-size: 26rpx;
  font-weight: 500;
}
