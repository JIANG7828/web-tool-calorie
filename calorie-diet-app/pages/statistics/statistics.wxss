.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.summary-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.summary-grid {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.macro-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.macro-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.macro-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.macro-label {
  width: 80rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.macro-bar-bg {
  flex: 1;
  height: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.macro-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.macro-value {
  width: 80rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 500;
}

.mode-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666666;
  border: 2rpx solid #e0e0e0;
}

.mode-btn.active {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  border-color: #4CAF50;
}

.chart-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-color.green { background-color: #4CAF50; }
.legend-color.red { background-color: #FF6B6B; }

.legend-line {
  width: 20rpx;
  height: 3rpx;
  background-color: #FF6B6B;
}

.legend-text {
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}
