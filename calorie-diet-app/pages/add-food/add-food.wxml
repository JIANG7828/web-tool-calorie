<view class="container">
  <view class="search-section">
    <input
      class="search-input"
      type="text"
      placeholder="搜索食物..."
      value="{{searchKeyword}}"
      bindinput="onSearch"
    />
  </view>

  <view wx:if="{{!searchKeyword && !currentCategory}}" class="last-foods-section">
    <text class="section-title">最近使用</text>
    <view wx:if="{{lastFoods.length > 0}}" class="last-foods-list">
      <view
        wx:for="{{lastFoods}}"
        wx:key="{{item}}"
        class="last-food-item"
        data-name="{{item}}"
        bindtap="useLastFood"
      >
        <text>{{item}}</text>
      </view>
    </view>
    <view wx:else class="empty-hint">
      <text>暂无最近记录</text>
    </view>
  </view>

  <view wx:if="{{!searchKeyword}}" class="categories-section">
    <text class="section-title">食物分类</text>
    <view class="categories-grid">
      <view
        wx:for="{{categories}}"
        wx:key="{{item.id}}"
        class="category-item {{currentCategory === item.id ? 'active' : ''}}"
        data-category="{{item.id}}"
        bindtap="selectCategory"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="foods-section">
    <text class="section-title">{{searchKeyword ? '搜索结果' : (currentCategory ? categories[currentCategory].name : '所有食物')}}</text>

    <view wx:if="{{searchResults.length > 0}}" class="foods-list">
      <view
        wx:for="{{searchResults}}"
        wx:key="{{item.id}}"
        class="food-item"
        data-id="{{item.id}}"
        bindtap="selectFood"
      >
        <view class="food-info">
          <text class="food-name">{{item.name}}</text>
          <text class="food-calories">{{item.caloriePerHundred}}千卡/100g</text>
        </view>
        <view class="food-arrow">
          <text>></text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">未找到相关食物</text>
      <button class="custom-btn" bindtap="useCustomCalories">
        <text>使用自定义热量</text>
      </button>
    </view>
  </view>

  <view wx:if="{{showFoodDetail}}" class="modal-overlay">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{selectedFood.name}}</text>
        <text class="modal-subtitle">{{selectedFood.caloriePerHundred}}千卡/100g</text>
      </view>

      <view class="portion-section">
        <text class="portion-title">选择份量</text>
        <view class="portion-buttons">
          <view
            wx:for="{{selectedFood.portions}}"
            wx:key="index"
            class="portion-btn {{selectedPortion.weight === item.weight ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="selectPortion"
          >
            <text class="portion-label">{{item.label}}</text>
            <text class="portion-weight">{{item.weight}}g</text>
          </view>
        </view>
      </view>

      <view class="calorie-preview">
        <text class="preview-label">热量</text>
        <text class="preview-value">{{(selectedFood.caloriePerHundred / 100 * selectedPortion.weight).toFixed(0)}} 千卡</text>
      </view>

      <view class="modal-actions">
        <button class="cancel-btn" bindtap="cancel">取消</button>
        <button class="confirm-btn" bindtap="confirmAdd">确认添加</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showCustomInput}}" class="modal-overlay">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">自定义食物</text>
        <text class="modal-subtitle">输入食物名称和热量</text>
      </view>

      <view class="input-section">
        <input
          class="input-field"
          type="text"
          placeholder="食物名称"
          bindinput="inputCustomFoodName"
        />
        <input
          class="input-field"
          type="digit"
          placeholder="热量（千卡）"
          bindinput="inputCustomCalories"
        />
      </view>

      <view class="modal-actions">
        <button class="cancel-btn" bindtap="cancel">取消</button>
        <button class="confirm-btn" bindtap="confirmCustom">确认添加</button>
      </view>
    </view>
  </view>
</view>
