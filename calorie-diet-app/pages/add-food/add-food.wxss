.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.last-foods-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.last-foods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.last-food-item {
  padding: 16rpx 24rpx;
  background-color: #E8F5E9;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #4CAF50;
}

.empty-hint {
  padding: 30rpx 0;
  text-align: center;
  color: #999999;
  font-size: 24rpx;
}

.categories-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.categories-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.category-item:active {
  transform: scale(0.95);
  background-color: #f0f0f0;
}

.category-item.active {
  background-color: #4CAF50;
  color: #ffffff;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 22rpx;
  color: inherit;
  font-weight: 500;
}

.category-item.active .category-name {
  color: #ffffff;
}

.foods-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.foods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.food-item:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.food-calories {
  font-size: 22rpx;
  color: #999999;
}

.food-arrow {
  color: #cccccc;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.custom-btn {
  padding: 20rpx 40rpx;
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 24rpx;
  border: none;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.modal-subtitle {
  font-size: 24rpx;
  color: #999999;
}

.portion-section {
  margin-bottom: 30rpx;
}

.portion-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.portion-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.portion-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.portion-btn.active {
  background-color: #4CAF50;
  color: #ffffff;
}

.portion-label {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.portion-weight {
  font-size: 22rpx;
  opacity: 0.7;
}

.calorie-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #E8F5E9;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.preview-label {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.preview-value {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: bold;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666666;
}

.confirm-btn {
  background-color: #4CAF50;
  color: #ffffff;
}

.input-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.input-field {
  width: 100%;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}
