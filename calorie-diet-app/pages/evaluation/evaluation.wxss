.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.score-header {
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
  color: #fff;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 auto 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 64rpx;
  font-weight: bold;
}

.score-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.rating-badge {
  font-size: 36rpx;
  font-weight: bold;
  padding: 10rpx 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: inline-block;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.score-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.score-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.score-bar-inner {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.score-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-name {
  font-size: 24rpx;
  color: #666;
}

.score-val {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.bmi-info {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #4CAF50;
}

.evaluation-section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.pros-list, .cons-list, .suggestions-list {
  padding-left: 10rpx;
}

.pro-item, .con-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.pro-icon {
  color: #4CAF50;
  font-weight: bold;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.con-icon {
  color: #F44336;
  font-weight: bold;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.pro-text, .con-text, .suggestion-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.suggestion-item {
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 3rpx solid #FF9800;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}

.next-meal-section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.next-meal-content {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.next-meal-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

.action-btn.primary {
  background: #4CAF50;
  color: #fff;
}

.week-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.week-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 10rpx;
}

.week-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.week-bar {
  width: 36rpx;
  background: #4CAF50;
  border-radius: 4rpx;
  min-height: 4%;
}

.week-bar.today {
  background: #FF6B35;
}

.week-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.week-label.today {
  color: #FF6B35;
  font-weight: bold;
}

.week-cal {
  font-size: 18rpx;
  color: #666;
  margin-top: 4rpx;
}
