.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

.upload-area {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 80rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.upload-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999999;
}

.image-preview {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.preview-img {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background-color: #f8f8f8;
}

.image-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.retake-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
}

.clear-btn {
  background-color: #f5f5f5;
  color: #666666;
}

.loading-area {
  text-align: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.results-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.result-item.selected {
  background-color: #E8F5E9;
  border-color: #4CAF50;
}

.result-left {
  flex: 1;
}

.result-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.result-detail {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.result-prob {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 600;
}

.portion-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.portion-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.portion-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  font-size: 24rpx;
  color: #666666;
}

.portion-tag.active {
  background-color: #E8F5E9;
  border-color: #4CAF50;
  color: #4CAF50;
}

.custom-weight {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 16rpx;
}

.weight-input {
  flex: 1;
  font-size: 28rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}

.cal-summary {
  text-align: center;
  padding: 30rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.cal-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.cal-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #4CAF50;
}

.cal-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.add-record-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.tips-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666666;
}
