{
  "envId": "vehicle-app-d1gsqheo6a1c88106",
  "region": "ap-shanghai",
  "functionRoot": "cloudfunctions/",
  "functions": [
    {
      "name": "auth-register",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {
        "JWT_SECRET": "health_app_jwt_secret_key_2025_change_me",
        "JWT_EXPIRE_HOURS": "168"
      }
    },
    {
      "name": "auth-login",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {
        "JWT_SECRET": "health_app_jwt_secret_key_2025_change_me",
        "JWT_EXPIRE_HOURS": "168"
      }
    },
    {
      "name": "auth-reset-password",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {
        "JWT_SECRET": "health_app_jwt_secret_key_2025_change_me"
      }
    }
  ],
  "app": {
    "serviceName": "vehicle-root",
    "framework": "static",
    "installCommand": "echo no install needed",
    "buildCommand": "",
    "outputDir": "dist"
